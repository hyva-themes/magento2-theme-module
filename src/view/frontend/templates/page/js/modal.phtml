declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\DeployMode;
use Hyva\Theme\ViewModel\HyvaCsp;
use Hyva\Theme\ViewModel\Modal;
use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;

// phpcs:disable Generic.Files.LineLength.TooLong

/** @var Template $block */
/** @var Escaper $escaper */
/** @var HyvaCsp $hyvaCsp */
/** @var ViewModelRegistry $viewModels */

$deployMode = $viewModels->require(DeployMode::class);

?>
<script>
    (function () {
        const modals = [];

        window.hyva.modal = function(options = {}) {
            <?php /* $el is not defined when hyva.modal is called within Object.assign() for example */ ?>
            if (this.$el && this.$el.dataset && this.$el.dataset.options) {
                try {
                    options = Object.assign(options, JSON.parse(this.$el.dataset.options || '{}'));
                } catch (e) {
                    throw new Error('Cannot read the dialog options from the data-options attribute: not valid JSON');
                }
            }

            const config = Object.assign({
                dialog: '<?= /* @noEscape */ Modal::DEFAULT_NAME ?>', <?php /* default dialog ref name */ ?>
                duration: 300, <?php /* ms before allowing subsequent hiding of modals for nested modals (see transition duration) */ ?>
                transitionEnter: 'transition ease-out duration-300',
                transitionEnterStart: 'opacity-0',
                transitionEnterEnd: 'opacity-100',
                transitionLeave: 'transition ease-in duration-300',
                transitionLeaveStart: 'opacity-100',
                transitionLeaveEnd: 'opacity-0',
            }, options);

            const resolvers = {};

            return {
                opened: {},
                show(dialog, trigger) {
                    const name = typeof dialog === 'string' ? dialog : config.dialog;
                    if (! name) {
                        return;
                    }
                    <?php /* Prevent adding the same modal on the stack twice */ ?>
                    if (this.opened[name]) {
                        return;
                    }
                    this.opened[name] = true;
                    modals.push({ name, instance: this, time: Date.now() });
                    return new Promise(resolve => { resolvers[name] = resolve; });
                },
                cancel() {
                    this.hide(false);
                },
                ok() {
                    this.hide(true);
                },
                hide(value) {
                    const name = Object.keys(this.opened).find(k => this.opened[k]);
                    if (!name) return;
                    this.opened[name] = false;
                    const idx = modals.findIndex(m => m.instance === this && m.name === name);
                    if (idx !== -1) modals.splice(idx, 1);
                    if (resolvers[name] !== undefined) {
                        resolvers[name](value);
                        delete resolvers[name];
                    }
                },
                /**
                 * @deprecated Use dialogConfig() instead, which is used by the default modal-container.phtml template.
                 * This method is kept for backwards compatibility with custom container templates.
                 */
                overlay(dialog) {
                    dialog = this.$el.dataset.dialogRefName || dialog;
                    const name = typeof dialog === 'string' ? dialog : config.dialog;
                    return Object.assign({}, this.dialogConfig(), {
                        ['@hyva-modal-show.window'](event) {
                            event.detail && event.detail.dialog === name && this.show(name, event.detail.focusAfterHide)
                        }
                    });
                },
                dialogConfig() {
                    const name = this.$el.dataset.dialogRefName || config.dialog;
                    return {
                        ['x-show']: () => name ? this.opened[name] : false,
                        ['x-transition:enter']: config.transitionEnter,
                        ['x-transition:enter-start']: config.transitionEnterStart,
                        ['x-transition:enter-end']: config.transitionEnterEnd,
                        ['x-transition:leave']: config.transitionLeave,
                        ['x-transition:leave-start']: config.transitionLeaveStart,
                        ['x-transition:leave-end']: config.transitionLeaveEnd,
                        ['@hyva-modal-show.window'](event) {
                            event.detail && event.detail.dialog === name && this.show(name);
                        },
                    };
                },
                showDialogOnInit() {
                    const name = this.$el.dataset.dialogRefName;
                    if (name) {
                        this.show(name);
                    }
                }
            };
        }

        window.hyva.modal.peek = () => modals.length > 0 && modals[modals.length - 1]

        window.hyva.modal.pop = function () {
            if (modals.length > 0) {
                modals[modals.length - 1].instance.hide();
            }
        }

        /**
         * @deprecated Native <dialog> handles focus trapping automatically.
         * Calling this function has no effect. Kept for backwards compatibility.
         */
        window.hyva.modal.excludeSelectorsFromFocusTrap = function (selectors) {}

        /**
         * @deprecated Native <dialog> with x-htmldialog handles ESC key and click-outside events.
         * These functions have no effect. Kept for backwards compatibility.
         */
        window.hyva.modal.eventListeners = {
            keydown: event => {},
            click: event => {}
        };
    })();

    window.addEventListener('alpine:init', () => {
        Alpine.data('hyvaModal', window.hyva.modal);
    }, {once: true});
</script>
<?php $hyvaCsp->registerInlineScript() ?>
